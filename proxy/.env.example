# -------------------------------------------------------
# Proxy-Konfiguration (Laptop A)
# Kopiere diese Datei zu .env und trage die echten IPs ein
# -------------------------------------------------------

# IP und Port des Backends auf Laptop B
BACKEND_URL=http://<LAPTOP-B-IP>:5000

# Netzwerk-IP von Laptop A + Port des Vue Dev Servers
# (nur für CORS relevant)
FRONTEND_URL=http://<LAPTOP-A-IP>:5173

# Port auf dem der Proxy läuft
PORT=3001
