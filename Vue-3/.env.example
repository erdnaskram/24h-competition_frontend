# -------------------------------------------------------
# Frontend-Konfiguration
# Kopiere diese Datei zu .env (lokal) oder .env.local (Netzwerk)
# -------------------------------------------------------

# Lokale Entwicklung (nur auf Laptop A selbst):
VITE_BACKEND_URL=http://localhost:3001

# Für Wettkampf-Betrieb (Tablets im Netzwerk):
# Lege eine .env.local Datei an und trage die Netzwerk-IP von Laptop A ein:
# VITE_BACKEND_URL=http://<LAPTOP-A-IP>:3001
